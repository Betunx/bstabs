# Black Sheep - Global .gitignore

# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
# Gestor de paquetes: pnpm (monorepo). pnpm-lock.yaml SÍ se versiona
# (instalación reproducible entre PCs). NO usar npm/yarn aquí.
package-lock.json
yarn.lock

# Environment Variables
.env
.env.local
.env.*.local
!.env.example

# Angular environment files — contienen Supabase URL/keys y adminEmail
# Copiar de environment.example.ts y rellenar valores reales
frontend/black-sheep-app/src/environments/environment.ts
frontend/black-sheep-app/src/environments/environment.prod.ts

# Claude Code: config local por máquina (rutas absolutas, no sincronizar)
.claude/settings.local.json

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Build outputs
dist/
build/
.angular/
*.tsbuildinfo

# Logs
logs/
*.log

# Docker
docker-compose.override.yml

# Database
*.db
*.sqlite

# OS
Thumbs.db
.DS_Store

# Test coverage
coverage/
.nyc_output/

# Temporary files
tmp/
temp/
*.tmp

# Scraper extracted tabs
scripts/scraper/extracted-tabs/

# Scraper generated output (datos generados, no fuente)
scripts/scraper/catalog-output/
scripts/scraper/mass-import-output/
scripts/scraper/queue-results/
scripts/scraper/queue-state.json
scripts/scraper/output/

# Scraper: modelo OCR binario (3.3 MB, se descarga aparte, no es fuente)
scripts/scraper/spa.traineddata

# Archivos obsoletos del proyecto (no commitear)
scripts/archive-obsolete/

# AWS
.aws/
*.pem

# Secrets
secrets/
*.key
*.cert

# Vercel (legacy - now using Cloudflare)
.vercel

# Archivos temporales de testing - nunca commitear
test-db-connection.js
test-*.txt
*.tmp
*temp*.json
temp-songs.json

# Prevenir archivos con paths absolutos corruptos
C:*
/C:*
